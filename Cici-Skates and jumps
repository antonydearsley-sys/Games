<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<title>Cici Skates</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{
  width:100%;height:100%;
  background:#0a1428;
  display:flex;justify-content:center;align-items:center;
  overflow:hidden;touch-action:none;
}
canvas{display:block;touch-action:none;}
</style>
</head>
<body>
<canvas id="c"></canvas>
<script>
'use strict';
const canvas = document.getElementById('c');
const ctx    = canvas.getContext('2d');

// ─── GAME DIMENSIONS (logical) ───────────────────────────────────────────────
// Portrait-friendly: tall on phone, wide on tablet/desktop
const GW = 480, GH = 700;
const FLOOR = 520;       // y of ice surface
const GRAVITY = 0.72;
const JVEL    = -16.5;

// ─── CANVAS SETUP ────────────────────────────────────────────────────────────
function setupCanvas(){
const dpr   = window.devicePixelRatio || 1;
const scale = Math.min(window.innerWidth/GW, window.innerHeight/GH);
const cssW  = Math.round(GW*scale);
const cssH  = Math.round(GH*scale);
canvas.style.width  = cssW+‘px’;
canvas.style.height = cssH+‘px’;
canvas.width  = cssW*dpr;
canvas.height = cssH*dpr;
ctx.setTransform(scale*dpr,0,0,scale*dpr,0,0);
}
setupCanvas();
window.addEventListener(‘resize’, setupCanvas);

// ─── STATE ────────────────────────────────────────────────────────────────────
let MODE=‘title’, score=0, best=0, tick=0;
let spd=4.5, spawnT=0, spawnGap=110;
let phase=0;          // 0-5, advances every ~80 score
let flashMsg=’’, flashTimer=0;

// difficulty phase table: [speed, spawnGap, doubleChance]
const PHASES=[
{spd:4.5,  gap:110, dbl:0.00, label:’’},
{spd:6.0,  gap:88,  dbl:0.00, label:‘⚡ Faster!’},
{spd:7.8,  gap:72,  dbl:0.12, label:‘🌪 Wind picks up!’},
{spd:9.5,  gap:58,  dbl:0.22, label:‘❄ Ice Storm!’},
{spd:11.5, gap:46,  dbl:0.35, label:‘💨 Blizzard!’},
{spd:14.0, gap:36,  dbl:0.50, label:‘☠ CHAOS!’},
];

// ─── PLAYER ───────────────────────────────────────────────────────────────────
const P={
x:100, y:FLOOR, vy:0, grounded:true,
W:32,  H:70,
jump(){ if(this.grounded){this.vy=JVEL; this.grounded=false;} },
update(){
if(!this.grounded){this.vy+=GRAVITY; this.y+=this.vy;}
if(this.y>=FLOOR){this.y=FLOOR; this.vy=0; this.grounded=true;}
}
};

// ─── OBSTACLES ────────────────────────────────────────────────────────────────
const ODEFS={
snowpile:{w:60, h:34},
icecone: {w:32, h:48},
snowman: {w:48, h:80},
barrier: {w:20, h:60},
};
let obs=[];

function spawnOne(xOffset=0){
const keys=Object.keys(ODEFS);
const t=keys[keys.length*Math.random()|0];
const d=ODEFS[t];
obs.push({type:t, x:GW+50+xOffset, w:d.w, h:d.h});
}
function spawnGroup(){
const ph=PHASES[phase];
spawnOne(0);
if(Math.random()<ph.dbl){
// double: pick gap 20-55px so they’re hard but jumpable
const gap=60+Math.random()*60|0;
spawnOne(gap);
}
}

// ─── PARALLAX ─────────────────────────────────────────────────────────────────
const MNTS =Array.from({length:8},(*,i)=>({ox:i*150+Math.random()*40, h:70+Math.random()*80}));
const TREES=Array.from({length:12},(*,i)=>({ox:i*90+Math.random()*40}));
let mx=0, tx=0;

// ─── SNOW ─────────────────────────────────────────────────────────────────────
const FLAKES=Array.from({length:80},()=>({
x:Math.random()*GW, y:Math.random()*GH,
r:Math.random()*2+0.4,
vx:-Math.random()*0.5-0.1,
vy:Math.random()*0.7+0.2
}));

// ─── ICE STREAKS ──────────────────────────────────────────────────────────────
const STREAKS=Array.from({length:12},()=>({
x:Math.random()*GW, y:FLOOR+8+Math.random()*60,
len:25+Math.random()*55, al:0.12+Math.random()*0.16
}));

// ─── INPUT ────────────────────────────────────────────────────────────────────
function act(){
if(MODE===‘title’){MODE=‘play’; reset();}
else if(MODE===‘play’){P.jump();}
else if(MODE===‘dead’){MODE=‘play’; reset();}
}
document.addEventListener(‘keydown’,e=>{
if(e.code===‘Space’||e.code===‘ArrowUp’){e.preventDefault(); act();}
});
canvas.addEventListener(‘pointerdown’,e=>{e.preventDefault(); act();});

// ─── RESET ────────────────────────────────────────────────────────────────────
function reset(){
P.y=FLOOR; P.vy=0; P.grounded=true;
obs=[]; score=0; tick=0;
phase=0; spd=PHASES[0].spd; spawnGap=PHASES[0].gap; spawnT=0;
flashMsg=’’; flashTimer=0;
}

// ─── COLLISION ────────────────────────────────────────────────────────────────
function hits(o){
const px=5, py=8;
const pl=P.x-P.W/2+px, pr=P.x+P.W/2-px;
const pt=P.y-P.H+py,   pb=P.y-3;
const ol=o.x+3, or2=o.x+o.w-3, ot=FLOOR-o.h+4, ob2=FLOOR;
return pl<or2&&pr>ol&&pt<ob2&&pb>ot;
}

// ─── UPDATE ───────────────────────────────────────────────────────────────────
function update(){
if(MODE!==‘play’) return;
tick++;
score+=0.06;
if(score>best) best=score;

// Advance phase
const newPhase=Math.min(5, score/80|0);
if(newPhase>phase){
phase=newPhase;
spd=PHASES[phase].spd;
spawnGap=PHASES[phase].gap;
if(PHASES[phase].label){ flashMsg=PHASES[phase].label; flashTimer=120; }
}
// Within-phase micro speed increase (keeps climbing between jumps)
const microSpd=PHASES[phase].spd + (score - phase*80)*0.022;
spd=Math.min(microSpd, PHASES[Math.min(5,phase+1)].spd);

P.update();

spawnT++;
if(spawnT>=spawnGap){spawnGroup(); spawnT=0; spawnGap=PHASES[phase].gap;}
obs.forEach(o=>o.x-=spd);
obs=obs.filter(o=>o.x>-160);
for(let o of obs){if(hits(o)){MODE=‘dead’; return;}}

mx-=spd*0.16; tx-=spd*0.40;
STREAKS.forEach(s=>{s.x-=spd*0.8; if(s.x<-90)s.x=GW+Math.random()*80;});
FLAKES.forEach(f=>{
f.x+=f.vx-(spd*0.04); f.y+=f.vy;
if(f.y>GH){f.y=-4; f.x=Math.random()*GW;} if(f.x<0)f.x=GW;
});

if(flashTimer>0) flashTimer–;
}

// ═════════════════════════════════════════════════════════════════════════════
// DRAW
// ═════════════════════════════════════════════════════════════════════════════

function drawSky(){
// sky colour shifts warmer/redder as phase increases (storm coming)
const r1=Math.min(60, 10+phase*8);
const g1=Math.max(14,26-phase*2);
const b1=Math.max(20,56-phase*6);
const r2=Math.min(120,28+phase*14);
const g2=Math.max(50,100-phase*10);
const b2=Math.max(80,190-phase*18);
const g=ctx.createLinearGradient(0,0,0,FLOOR);
g.addColorStop(0,`rgb(${r1},${g1},${b1})`);
g.addColorStop(0.5,`rgb(${r2},${g2},${b2})`);
g.addColorStop(1,`rgb(${Math.min(100,60+phase*8)},${Math.max(100,155-phase*15)},${Math.max(90,200-phase*18)})`);
ctx.fillStyle=g; ctx.fillRect(0,0,GW,FLOOR);
}

function drawMoon(){
ctx.save();
const alpha=Math.max(0.1,1-phase*0.18);
ctx.globalAlpha=alpha;
const g=ctx.createRadialGradient(380,55,0,380,55,60);
g.addColorStop(0,‘rgba(255,248,210,0.45)’); g.addColorStop(1,‘rgba(255,248,210,0)’);
ctx.fillStyle=g; ctx.beginPath(); ctx.arc(380,55,60,0,Math.PI*2); ctx.fill();
ctx.fillStyle=’#fff8d0’; ctx.beginPath(); ctx.arc(380,55,26,0,Math.PI*2); ctx.fill();
ctx.fillStyle=’#f0e090’; ctx.beginPath(); ctx.arc(390,47,18,0,Math.PI*2); ctx.fill();
ctx.restore();
}

function drawMountains(){
for(let m of MNTS){
const x=((m.ox+mx%(GW+160))%(GW+160))-80;
ctx.fillStyle=’#101e3a’;
ctx.beginPath(); ctx.moveTo(x,FLOOR); ctx.lineTo(x+90,FLOOR-m.h); ctx.lineTo(x+180,FLOOR); ctx.closePath(); ctx.fill();
ctx.fillStyle=’#ddeeff’;
ctx.beginPath(); ctx.moveTo(x+90,FLOOR-m.h); ctx.lineTo(x+74,FLOOR-m.h+26); ctx.lineTo(x+106,FLOOR-m.h+26); ctx.closePath(); ctx.fill();
}
}

function drawTrees(){
for(let t of TREES){
const x=((t.ox+tx%(GW+110))%(GW+110))-55;
ctx.fillStyle=’#0a1a30’; ctx.fillRect(x+9,FLOOR-26,7,26);
[[18,0],[22,13],[18,24]].forEach(([hw,oy])=>{
ctx.fillStyle=’#14305a’;
ctx.beginPath(); ctx.moveTo(x+12,FLOOR-78+oy); ctx.lineTo(x+12-hw,FLOOR-54+oy); ctx.lineTo(x+12+hw,FLOOR-54+oy); ctx.closePath(); ctx.fill();
ctx.fillStyle=‘rgba(210,235,255,0.85)’;
ctx.beginPath(); ctx.moveTo(x+12,FLOOR-78+oy); ctx.lineTo(x+12-hw*.42,FLOOR-66+oy); ctx.lineTo(x+12+hw*.42,FLOOR-66+oy); ctx.closePath(); ctx.fill();
});
}
}

function drawGround(){
const g=ctx.createLinearGradient(0,FLOOR,0,GH);
g.addColorStop(0,’#a8d8f2’); g.addColorStop(0.3,’#88c0e0’); g.addColorStop(1,’#5898c4’);
ctx.fillStyle=g; ctx.fillRect(0,FLOOR,GW,GH-FLOOR);
ctx.save();
for(let s of STREAKS){
ctx.globalAlpha=s.al; ctx.strokeStyle=’#ffffff’; ctx.lineWidth=1.8;
ctx.beginPath(); ctx.moveTo(s.x,s.y); ctx.lineTo(s.x+s.len,s.y+5); ctx.stroke();
}
ctx.globalAlpha=1; ctx.restore();
ctx.fillStyle=’#ffffff’; ctx.fillRect(0,FLOOR,GW,3);
ctx.save(); ctx.strokeStyle=‘rgba(255,255,255,0.18)’; ctx.lineWidth=1.5; ctx.setLineDash([16,12]);
[FLOOR+40,FLOOR+80].forEach(y=>{ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(GW,y); ctx.stroke();});
ctx.setLineDash([]); ctx.restore();
}

function drawSnow(){
for(let f of FLAKES){
ctx.fillStyle=`rgba(255,255,255,${0.4+f.r*0.1})`;
ctx.beginPath(); ctx.arc(f.x,f.y,f.r,0,Math.PI*2); ctx.fill();
}
}

// ─── CICI ─────────────────────────────────────────────────────────────────────
function drawCici(dead){
const px=P.x, py=P.y, t=tick;
const sw = dead?0:Math.sin(t*0.28);
const bob= dead?0:Math.abs(sw)*2.5;

ctx.save();
ctx.translate(px,py);
if(dead){ctx.translate(14,-16); ctx.rotate(0.4);}

const boot=’#f4f4f4’, blade=’#9999bb’, tight=’#88b8df’;

// Left leg
ctx.save(); ctx.rotate(sw*-0.52);
ctx.strokeStyle=tight; ctx.lineWidth=8; ctx.lineCap=‘round’;
ctx.beginPath(); ctx.moveTo(-7,-16); ctx.lineTo(-10,0); ctx.stroke();
ctx.fillStyle=boot; ctx.strokeStyle=’#ccc’; ctx.lineWidth=1.5;
ctx.beginPath(); ctx.ellipse(-12,2,11,5,-0.15,0,Math.PI*2); ctx.fill(); ctx.stroke();
ctx.strokeStyle=blade; ctx.lineWidth=2; ctx.lineCap=‘butt’;
ctx.beginPath(); ctx.moveTo(-22,7); ctx.lineTo(-2,7); ctx.stroke();
ctx.restore();

// Right leg
ctx.save(); ctx.rotate(sw*0.52);
ctx.strokeStyle=tight; ctx.lineWidth=8; ctx.lineCap=‘round’;
ctx.beginPath(); ctx.moveTo(7,-16); ctx.lineTo(10,0); ctx.stroke();
ctx.fillStyle=boot; ctx.strokeStyle=’#ccc’; ctx.lineWidth=1.5;
ctx.beginPath(); ctx.ellipse(12,2,11,5,0.15,0,Math.PI*2); ctx.fill(); ctx.stroke();
ctx.strokeStyle=blade; ctx.lineWidth=2; ctx.lineCap=‘butt’;
ctx.beginPath(); ctx.moveTo(2,7); ctx.lineTo(22,7); ctx.stroke();
ctx.restore();

const BT=-74+bob;

// Tights upper
ctx.fillStyle=’#a6cae6’;
ctx.beginPath(); ctx.moveTo(-11,-16); ctx.lineTo(11,-16); ctx.lineTo(13,-28); ctx.lineTo(-13,-28); ctx.closePath(); ctx.fill();

// Dress
ctx.fillStyle=’#4478cc’;
ctx.beginPath();
ctx.moveTo(-13,-28); ctx.lineTo(-14,BT+22);
ctx.quadraticCurveTo(-14,BT+12,0,BT+10);
ctx.quadraticCurveTo(14,BT+12,14,BT+22);
ctx.lineTo(13,-28); ctx.closePath(); ctx.fill();

// Skirt
ctx.fillStyle=’#5588ee’;
ctx.beginPath();
ctx.moveTo(-18,-30); ctx.quadraticCurveTo(0,-22,18,-30);
ctx.lineTo(13,-18); ctx.lineTo(-13,-18); ctx.closePath(); ctx.fill();
ctx.strokeStyle=‘rgba(255,255,255,0.7)’; ctx.lineWidth=1.8;
ctx.beginPath(); ctx.moveTo(-18,-30); ctx.quadraticCurveTo(0,-22,18,-30); ctx.stroke();

// Collar
ctx.fillStyle=‘rgba(255,255,255,0.8)’;
ctx.beginPath(); ctx.ellipse(0,BT+22,6.5,3,0,0,Math.PI*2); ctx.fill();

// Arms
const as=dead?0:Math.sin(t*0.28+1.2)*0.5;
ctx.save(); ctx.translate(-13,BT+27); ctx.rotate(-0.42+as);
ctx.strokeStyle=’#4478cc’; ctx.lineWidth=9; ctx.lineCap=‘round’;
ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(-3,19); ctx.stroke();
ctx.fillStyle=’#f8c098’; ctx.beginPath(); ctx.arc(-4,21,5,0,Math.PI*2); ctx.fill();
ctx.restore();
ctx.save(); ctx.translate(13,BT+27); ctx.rotate(0.42-as);
ctx.strokeStyle=’#4478cc’; ctx.lineWidth=9; ctx.lineCap=‘round’;
ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(3,19); ctx.stroke();
ctx.fillStyle=’#f8c098’; ctx.beginPath(); ctx.arc(4,21,5,0,Math.PI*2); ctx.fill();
ctx.restore();

const hy=BT+7;
ctx.fillStyle=’#f8c098’; ctx.fillRect(-4,hy,8,9);

// Hair
ctx.fillStyle=’#e8b820’;
ctx.beginPath(); ctx.ellipse(0,hy-11,14,16,0,0,Math.PI*2); ctx.fill();
ctx.fillStyle=’#f8c098’;
ctx.beginPath(); ctx.ellipse(0,hy-9,12,14,0,0,Math.PI*2); ctx.fill();
ctx.fillStyle=’#e8b820’;
ctx.beginPath(); ctx.ellipse(0,hy-23,12.5,6.5,0,Math.PI,0); ctx.fill();

// Pigtail L
ctx.save(); ctx.translate(-14,hy-13); ctx.rotate(-0.28);
ctx.fillStyle=’#e8b820’; ctx.beginPath(); ctx.ellipse(0,0,5.5,9,0,0,Math.PI*2); ctx.fill();
ctx.fillStyle=’#ff5590’;
ctx.beginPath(); ctx.moveTo(0,-8); ctx.bezierCurveTo(-7,-14,-7,-3,0,-8); ctx.fill();
ctx.beginPath(); ctx.moveTo(0,-8); ctx.bezierCurveTo(7,-14,7,-3,0,-8); ctx.fill();
ctx.fillStyle=’#ff88bb’; ctx.beginPath(); ctx.arc(0,-8,2.2,0,Math.PI*2); ctx.fill();
ctx.restore();

// Pigtail R
ctx.save(); ctx.translate(14,hy-13); ctx.rotate(0.28);
ctx.fillStyle=’#e8b820’; ctx.beginPath(); ctx.ellipse(0,0,5.5,9,0,0,Math.PI*2); ctx.fill();
ctx.fillStyle=’#ff5590’;
ctx.beginPath(); ctx.moveTo(0,-8); ctx.bezierCurveTo(-7,-14,-7,-3,0,-8); ctx.fill();
ctx.beginPath(); ctx.moveTo(0,-8); ctx.bezierCurveTo(7,-14,7,-3,0,-8); ctx.fill();
ctx.fillStyle=’#ff88bb’; ctx.beginPath(); ctx.arc(0,-8,2.2,0,Math.PI*2); ctx.fill();
ctx.restore();

// Eyes
ctx.fillStyle=’#1e1010’;
ctx.beginPath(); ctx.ellipse(-4.5,hy-11,2.8,3.2,0,0,Math.PI*2); ctx.fill();
ctx.beginPath(); ctx.ellipse(4.5, hy-11,2.8,3.2,0,0,Math.PI*2); ctx.fill();
ctx.fillStyle=’#fff’;
ctx.beginPath(); ctx.arc(-3.3,hy-12.5,1.2,0,Math.PI*2); ctx.fill();
ctx.beginPath(); ctx.arc(5.7, hy-12.5,1.2,0,Math.PI*2); ctx.fill();

// Eyelashes
ctx.strokeStyle=’#1e1010’; ctx.lineWidth=1.2; ctx.lineCap=‘round’;
[[-7,hy-14.5,-4.5,hy-16],[-5.5,hy-15.5,-3,hy-16.5],[-2.5,hy-14.5,-4,hy-16]].forEach(
([x1,y1,x2,y2])=>{ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();}
);
[[7,hy-14.5,4.5,hy-16],[5.5,hy-15.5,3,hy-16.5],[2.5,hy-14.5,4,hy-16]].forEach(
([x1,y1,x2,y2])=>{ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();}
);

// Nose
ctx.fillStyle=’#df9070’; ctx.beginPath(); ctx.ellipse(0,hy-6.5,1.8,1.3,0,0,Math.PI*2); ctx.fill();
// Cheeks
ctx.fillStyle=‘rgba(255,135,115,0.36)’;
ctx.beginPath(); ctx.ellipse(-6.5,hy-5,4.5,2.8,0,0,Math.PI*2); ctx.fill();
ctx.beginPath(); ctx.ellipse(6.5, hy-5,4.5,2.8,0,0,Math.PI*2); ctx.fill();
// Smile
ctx.strokeStyle=’#a84828’; ctx.lineWidth=1.8; ctx.lineCap=‘round’;
ctx.beginPath(); ctx.moveTo(-3.5,hy-1); ctx.quadraticCurveTo(0,hy+2.5,3.5,hy-1); ctx.stroke();

ctx.restore();
}

// ─── OBSTACLES ────────────────────────────────────────────────────────────────
function drawObs(o){
ctx.save();
ctx.translate(o.x,FLOOR);

if(o.type===‘snowpile’){
ctx.fillStyle=‘rgba(60,110,180,0.2)’;
ctx.beginPath(); ctx.ellipse(30,3,32,8,0,0,Math.PI*2); ctx.fill();
[{x:30,y:0,rx:28,ry:13},{x:18,y:-13,rx:22,ry:13},{x:38,y:-9,rx:18,ry:12}].forEach(b=>{
ctx.fillStyle=’#d8eeff’;
ctx.beginPath(); ctx.ellipse(b.x,b.y,b.rx,b.ry,0,0,Math.PI*2); ctx.fill();
ctx.strokeStyle=‘rgba(170,215,245,0.7)’; ctx.lineWidth=1.5; ctx.stroke();
});
ctx.fillStyle=‘rgba(255,255,255,0.62)’;
ctx.beginPath(); ctx.ellipse(14,-21,8,5,-0.4,0,Math.PI*2); ctx.fill();
ctx.beginPath(); ctx.ellipse(40,-15,6,3.5,0.3,0,Math.PI*2); ctx.fill();
}

else if(o.type===‘icecone’){
ctx.fillStyle=‘rgba(60,110,180,0.2)’;
ctx.beginPath(); ctx.ellipse(16,3,17,5,0,0,Math.PI*2); ctx.fill();
ctx.fillStyle=’#7ad4f8’;
ctx.beginPath(); ctx.moveTo(16,-o.h); ctx.lineTo(1,0); ctx.lineTo(31,0); ctx.closePath(); ctx.fill();
ctx.fillStyle=‘rgba(255,255,255,0.36)’;
ctx.beginPath(); ctx.moveTo(16,-o.h+5); ctx.lineTo(9,-8); ctx.lineTo(19,-13); ctx.closePath(); ctx.fill();
ctx.strokeStyle=’#44aadd’; ctx.lineWidth=1.8;
ctx.beginPath(); ctx.moveTo(16,-o.h); ctx.lineTo(1,0); ctx.lineTo(31,0); ctx.closePath(); ctx.stroke();
ctx.fillStyle=’#fff’; ctx.beginPath(); ctx.arc(16,-o.h+2,3,0,Math.PI*2); ctx.fill();
}

else if(o.type===‘snowman’){
ctx.fillStyle=‘rgba(60,110,180,0.2)’;
ctx.beginPath(); ctx.ellipse(24,3,22,6,0,0,Math.PI*2); ctx.fill();
ctx.fillStyle=’#dcf0ff’; ctx.strokeStyle=’#a8d2ec’; ctx.lineWidth=1.8;
ctx.beginPath(); ctx.arc(24,-18,19,0,Math.PI*2); ctx.fill(); ctx.stroke();
ctx.fillStyle=’#e8f6ff’; ctx.beginPath(); ctx.arc(24,-50,14,0,Math.PI*2); ctx.fill(); ctx.stroke();
ctx.fillStyle=’#f2faff’; ctx.beginPath(); ctx.arc(24,-71,10,0,Math.PI*2); ctx.fill(); ctx.stroke();
ctx.fillStyle=‘rgba(255,255,255,0.5)’;
ctx.beginPath(); ctx.ellipse(17,-26,6,4,-0.4,0,Math.PI*2); ctx.fill();
ctx.fillStyle=’#1c2a40’;
ctx.beginPath(); ctx.ellipse(24,-80,13,4,0,0,Math.PI*2); ctx.fill();
ctx.fillRect(13,-100,22,22);
ctx.fillStyle=’#cc2244’; ctx.fillRect(13,-84,22,5);
ctx.fillStyle=’#181e2a’;
ctx.beginPath(); ctx.arc(20,-73,2.1,0,Math.PI*2); ctx.fill();
ctx.beginPath(); ctx.arc(28,-73,2.1,0,Math.PI*2); ctx.fill();
ctx.fillStyle=’#ff7733’;
ctx.beginPath(); ctx.moveTo(24,-71); ctx.lineTo(33,-69); ctx.lineTo(24,-67); ctx.closePath(); ctx.fill();
ctx.fillStyle=’#181e2a’;
for(let i=-2;i<=2;i++){ctx.beginPath(); ctx.arc(24+i*2.6,-65+Math.abs(i)*1.6,1.3,0,Math.PI*2); ctx.fill();}
ctx.fillStyle=’#cc2244’;
ctx.beginPath(); ctx.ellipse(24,-61,15,4.5,0,0,Math.PI*2); ctx.fill();
ctx.fillStyle=’#ff4466’; ctx.fillRect(28,-63,4,9);
ctx.fillStyle=’#181e2a’;
[-40,-49,-58].forEach(by=>{ctx.beginPath(); ctx.arc(24,by,2.1,0,Math.PI*2); ctx.fill();});
ctx.strokeStyle=’#7a5522’; ctx.lineWidth=3; ctx.lineCap=‘round’;
ctx.beginPath(); ctx.moveTo(10,-49); ctx.lineTo(-1,-42); ctx.stroke();
ctx.beginPath(); ctx.moveTo(-1,-42); ctx.lineTo(-5,-38); ctx.stroke();
ctx.beginPath(); ctx.moveTo(38,-49); ctx.lineTo(49,-42); ctx.stroke();
ctx.beginPath(); ctx.moveTo(49,-42); ctx.lineTo(53,-38); ctx.stroke();
}

else if(o.type===‘barrier’){
ctx.fillStyle=‘rgba(60,110,180,0.2)’;
ctx.beginPath(); ctx.ellipse(10,3,14,5,0,0,Math.PI*2); ctx.fill();
ctx.fillStyle=’#aa3d00’;
ctx.beginPath(); ctx.moveTo(-6,0); ctx.lineTo(26,0); ctx.lineTo(22,-7); ctx.lineTo(-2,-7); ctx.closePath(); ctx.fill();
ctx.fillStyle=’#ff8800’; ctx.fillRect(1,-o.h,18,o.h-7);
ctx.fillStyle=’#fff’;
ctx.fillRect(1,-o.h+8,18,9);
ctx.fillRect(1,-o.h+27,18,9);
ctx.fillRect(1,-o.h+46,18,9);
ctx.fillStyle=‘rgba(0,0,0,0.13)’; ctx.fillRect(15,-o.h,4,o.h-7);
ctx.fillStyle=’#ffaa33’;
ctx.beginPath(); ctx.ellipse(10,-o.h,9,4.5,0,0,Math.PI*2); ctx.fill();
}

ctx.restore();
}

// ─── UI HELPERS ──────────────────────────────────────────────────────────────
function pill(x,y,w,h,r,fill,stroke,lw=2){
ctx.beginPath();
ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.arcTo(x+w,y,x+w,y+r,r);
ctx.lineTo(x+w,y+h-r); ctx.arcTo(x+w,y+h,x+w-r,y+h,r);
ctx.lineTo(x+r,y+h); ctx.arcTo(x,y+h,x,y+h-r,r);
ctx.lineTo(x,y+r); ctx.arcTo(x,y,x+r,y,r); ctx.closePath();
if(fill){ctx.fillStyle=fill; ctx.fill();}
if(stroke){ctx.strokeStyle=stroke; ctx.lineWidth=lw; ctx.stroke();}
}

// phase colour for accents
function phaseColor(){
const cols=[’#5599ff’,’#55ddff’,’#55ffaa’,’#ffdd33’,’#ff8833’,’#ff3333’];
return cols[phase];
}

function drawHUD(){
ctx.save();
const pc=phaseColor();
// Score pill – big and thumb-readable
pill(14,14,170,46,13,‘rgba(4,10,38,0.78)’,pc,2.5);
ctx.fillStyle=’#fff’; ctx.font=‘bold 26px system-ui,sans-serif’; ctx.textAlign=‘left’;
ctx.fillText(’⛸ ’+Math.floor(score), 30, 44);

// Best
if(best>0){
pill(GW-180,14,166,46,13,‘rgba(4,10,38,0.78)’,‘rgba(255,200,60,0.55)’,2);
ctx.fillStyle=’#ffd44a’; ctx.font=‘bold 20px system-ui,sans-serif’; ctx.textAlign=‘right’;
ctx.fillText(’★ ’+Math.floor(best), GW-20, 44);
}

// Speed phase bar (bottom of screen above tap hint)
const barW=GW-28, barH=8, barX=14, barY=GH-70;
pill(barX,barY,barW,barH,4,‘rgba(4,10,38,0.6)’,null);
const fill=(phase+(score-phase*80)/80)/6;
const fg=ctx.createLinearGradient(barX,0,barX+barW,0);
fg.addColorStop(0,’#4488ff’); fg.addColorStop(0.5,’#44ffdd’); fg.addColorStop(1,’#ff4444’);
pill(barX,barY,Math.max(barH,barW*fill),barH,4,fg,null);
ctx.fillStyle=‘rgba(255,255,255,0.5)’; ctx.font=‘11px system-ui,sans-serif’; ctx.textAlign=‘left’;
ctx.fillText(‘SPEED’,barX,barY-4);
ctx.textAlign=‘right’;
ctx.fillText(‘Phase ‘+(phase+1)+’/6’,GW-barX,barY-4);

// Tap hint at bottom
pill(GW/2-120,GH-52,240,36,18,‘rgba(4,10,38,0.55)’,‘rgba(255,255,255,0.15)’,1.5);
ctx.fillStyle=‘rgba(255,255,255,0.55)’; ctx.font=‘bold 14px system-ui,sans-serif’; ctx.textAlign=‘center’;
ctx.fillText(‘TAP / SPACE  to jump’,GW/2,GH-28);

ctx.restore();
}

function drawFlash(){
if(flashTimer<=0||!flashMsg) return;
const alpha=Math.min(1,flashTimer/30);
ctx.save();
ctx.globalAlpha=alpha;
ctx.fillStyle=‘rgba(10,20,60,0.7)’;
pill(GW/2-140,GH/2-110,280,56,14,‘rgba(10,20,60,0.8)’,phaseColor(),2.5);
ctx.fillStyle=’#ffffff’; ctx.font=‘bold 28px system-ui,sans-serif’; ctx.textAlign=‘center’;
ctx.shadowColor=phaseColor(); ctx.shadowBlur=18;
ctx.fillText(flashMsg,GW/2,GH/2-74);
ctx.shadowBlur=0; ctx.restore();
}

function drawTitle(){
ctx.save();
pill(40,GH*0.18,GW-80,GH*0.5,22,‘rgba(5,14,48,0.86)’,‘rgba(90,170,255,0.55)’,2.5);
ctx.textAlign=‘center’;
ctx.fillStyle=’#fff’; ctx.font=‘bold 52px system-ui,sans-serif’;
ctx.shadowColor=’#4499ff’; ctx.shadowBlur=28;
ctx.fillText(‘Cici Skates’,GW/2,GH*0.18+72); ctx.shadowBlur=0;
ctx.fillStyle=’#88ccff’; ctx.font=‘18px system-ui,sans-serif’;
ctx.fillText(‘Endless Ice Runner’,GW/2,GH*0.18+102);

ctx.fillStyle=‘rgba(200,230,255,0.7)’; ctx.font=‘13px system-ui,sans-serif’;
ctx.fillText(‘6 speed phases  ·  gets brutal fast!’,GW/2,GH*0.18+128);

const p=0.93+0.07*Math.sin(tick*0.06);
ctx.save(); ctx.translate(GW/2,GH*0.18+180); ctx.scale(p,p);
pill(-118,-32,236,64,32,’#1a7eee’,‘rgba(90,190,255,0.9)’,2.5);
ctx.fillStyle=’#fff’; ctx.font=‘bold 26px system-ui,sans-serif’; ctx.textAlign=‘center’;
ctx.fillText(‘▶  Start Skating’,0,10);
ctx.restore();

ctx.fillStyle=‘rgba(140,180,220,0.65)’; ctx.font=‘15px system-ui,sans-serif’;
ctx.fillText(‘Tap anywhere to jump’,GW/2,GH*0.18+235);
ctx.restore();
}

function drawGameOver(){
ctx.save();
pill(GW/2-200,GH/2-140,400,260,22,‘rgba(4,10,40,0.92)’,‘rgba(255,90,70,0.65)’,2.5);
ctx.textAlign=‘center’;
ctx.fillStyle=’#ff4433’; ctx.font=‘bold 46px system-ui,sans-serif’;
ctx.shadowColor=’#ff2200’; ctx.shadowBlur=18;
ctx.fillText(‘Game Over!’,GW/2,GH/2-85); ctx.shadowBlur=0;
ctx.fillStyle=’#fff’; ctx.font=‘22px system-ui,sans-serif’;
ctx.fillText(‘Score: ‘+Math.floor(score),GW/2,GH/2-48);
ctx.fillStyle=’#ffd44a’; ctx.font=‘18px system-ui,sans-serif’;
ctx.fillText(’★ Best: ’+Math.floor(best),GW/2,GH/2-18);
ctx.fillStyle=‘rgba(180,210,255,0.7)’; ctx.font=‘14px system-ui,sans-serif’;
ctx.fillText(‘Phase reached: ‘+(phase+1)+’/6’,GW/2,GH/2+10);

const p=0.95+0.05*Math.sin(tick*0.09);
ctx.save(); ctx.translate(GW/2,GH/2+72); ctx.scale(p,p);
pill(-106,-30,212,60,30,’#22bb66’,‘rgba(70,255,130,0.8)’,2.5);
ctx.fillStyle=’#fff’; ctx.font=‘bold 24px system-ui,sans-serif’; ctx.textAlign=‘center’;
ctx.fillText(‘▶  Try Again’,0,10);
ctx.restore();
ctx.restore();
}

// ─── MAIN LOOP ────────────────────────────────────────────────────────────────
function loop(){
if(MODE!==‘play’){
tick++;
FLAKES.forEach(f=>{
f.x+=f.vx; f.y+=f.vy;
if(f.y>GH){f.y=-4; f.x=Math.random()*GW;} if(f.x<0)f.x=GW;
});
}
update();

drawSky(); drawMoon(); drawMountains(); drawTrees();
drawGround(); drawSnow();
obs.forEach(drawObs);
drawCici(MODE===‘dead’);
drawHUD();
drawFlash();
if(MODE===‘title’) drawTitle();
if(MODE===‘dead’)  drawGameOver();

requestAnimationFrame(loop);
}
loop();
</script>

